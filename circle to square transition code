// Signed distance to circle centered at 0
// create a circle

float sdCircle(vec2 p, float radius) {
    return length(p) - radius;        // < 0 inside, 0 on edge, > 0 outside
}

//define the square that is centred about the circle with the same width as its diameter
float sdSquare(vec2 p, float halfSize) {
    vec2 d = abs(p) - vec2(halfSize);
    float outside = length(max(d, 0.0));
    float inside  = min(max(d.x, d.y), 0.0);
    return outside/2. - inside/1.5;  // < 0 inside, 0 on edge, > 0 outside
}
//trying to configure a square that goes beyond the dimensions of the circle
float odSquare(vec2 p, float halfSize) {
    vec2 d = abs(p) - vec2(halfSize);
    float outside = length(min(d, 0.0));
    float inside  = min(max(d.x, d.y), 0.0);
    return outside/2. - inside/2.;   // < 0 inside, 0 on edge, > 0 outside
}



void main() {
    vec2 p = uv(); 

    // --- SHAPE TRANSITION ---
    float halfSize = 0.3;//controls the distance between outside squares
    float radius   = 0.6;

    float dSquare  = sdSquare(p, halfSize);
    float oSquare  = odSquare(p, halfSize);
    float dCircle  = sdCircle(p, radius);

    // t oscillates between 0 and 1 over time
    float t = 0.5 + 0.5 * sin(time);
    // 0 = square, 1 = circle
    float d      = mix(dSquare, dCircle, t);
    float dPrime = mix(oSquare,  dCircle, t);

    // Shape mask with soft edge
    float edge       = 0.05;
    float finalshape = mix(dPrime, d, 0.1);
    float shape      = 1.0 - smoothstep(0.01, edge, finalshape);  // 1 inside blended shape

    // --- ripple the colours in the bands

    // Distance from center for ripple pattern
    float r = length(p);

    // Ripple value (0..1): expanding rings over time
    float wave = 0.5 + 0.5 * sin(20.0 * r - time * 4.0);

    // Map ripple to HSV for nicer color cycling
    float hue = fract(wave + time * 0.1); // hue shifts slowly
    float sat = 1.0;
    float val = 1.0;

    vec3 squareColor = hsv2rgb(vec3(hue, sat, val));

    // Background color
    vec3 bg = vec3(0.03, 0.03, 0.05);

    // Use the *blended* shape mask instead of `inside`
    vec3 col = mix(bg, squareColor, shape);

    gl_FragColor = vec4(col, 1.0);
}
